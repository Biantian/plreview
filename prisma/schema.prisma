generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Severity {
  low
  medium
  high
  critical
}

enum ReviewStatus {
  pending
  running
  completed
  partial
  failed
}

enum DocumentBlockType {
  heading
  paragraph
  list_item
}

enum ListKind {
  unordered
  ordered
}

enum LlmProfileMode {
  live
  demo
}

model Document {
  id             String              @id @default(cuid())
  title          String
  filename       String
  fileType       String
  rawText        String
  paragraphCount Int
  blockCount     Int                 @default(0)
  createdAt      DateTime            @default(now())
  paragraphs     DocumentParagraph[]
  blocks         DocumentBlock[]
  reviewJobs     ReviewJob[]
}

model DocumentBlock {
  id         String            @id @default(cuid())
  documentId String
  blockIndex Int
  blockType  DocumentBlockType
  text       String
  level      Int?
  listKind   ListKind?
  charStart  Int
  charEnd    Int
  document   Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, blockIndex])
  @@index([documentId])
}

model DocumentParagraph {
  id             String   @id @default(cuid())
  documentId     String
  paragraphIndex Int
  text           String
  charStart      Int
  charEnd        Int
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, paragraphIndex])
  @@index([documentId])
}

model Rule {
  id             String        @id @default(cuid())
  name           String
  category       String
  description    String
  promptTemplate String
  severity       Severity
  enabled        Boolean       @default(true)
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  versions       RuleVersion[]
  annotations    Annotation[]
}

model RuleVersion {
  id                     String       @id @default(cuid())
  ruleId                 String
  version                Int
  nameSnapshot           String
  descriptionSnapshot    String
  promptTemplateSnapshot String
  severitySnapshot       Severity
  createdAt              DateTime     @default(now())
  rule                   Rule         @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  annotations            Annotation[]
  batchRules             ReviewBatchRule[]

  @@unique([ruleId, version])
  @@index([ruleId])
}

model LlmProfile {
  id               String         @id @default(cuid())
  name             String
  provider         String
  vendorKey        String         @default("openai_compatible")
  mode             LlmProfileMode @default(live)
  apiStyle         String
  baseUrl          String
  defaultModel     String
  modelOptionsJson String?
  apiKeyEncrypted  String?
  apiKeyLast4      String?
  hasApiKey        Boolean        @default(false)
  enabled          Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  reviewJobs       ReviewJob[]
  reviewBatches    ReviewBatch[]
}

model ReviewBatch {
  id                String       @id @default(cuid())
  name              String
  llmProfileId      String?
  providerSnapshot  String
  modelNameSnapshot String
  createdAt         DateTime     @default(now())
  llmProfile        LlmProfile?  @relation(fields: [llmProfileId], references: [id], onDelete: SetNull)
  reviewJobs        ReviewJob[]
  batchRules        ReviewBatchRule[]

  @@index([llmProfileId])
}

model ReviewBatchRule {
  id            String      @id @default(cuid())
  reviewBatchId String
  ruleVersionId String
  reviewBatch   ReviewBatch @relation(fields: [reviewBatchId], references: [id], onDelete: Cascade)
  ruleVersion   RuleVersion @relation(fields: [ruleVersionId], references: [id], onDelete: Cascade)

  @@unique([reviewBatchId, ruleVersionId])
  @@index([reviewBatchId])
  @@index([ruleVersionId])
}

model ReviewJob {
  id                  String       @id @default(cuid())
  batchId             String?
  documentId          String
  llmProfileId        String?
  profileNameSnapshot String?
  providerSnapshot    String
  baseUrlSnapshot     String?
  modelNameSnapshot   String
  status              ReviewStatus @default(pending)
  summary             String?
  overallScore        Int?
  reportMarkdown      String?
  errorMessage        String?
  createdAt           DateTime     @default(now())
  finishedAt          DateTime?
  reviewBatch         ReviewBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  document            Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  llmProfile          LlmProfile?  @relation(fields: [llmProfileId], references: [id], onDelete: SetNull)
  annotations         Annotation[]

  @@index([batchId])
  @@index([documentId])
  @@index([llmProfileId])
}

model Annotation {
  id            String     @id @default(cuid())
  reviewJobId   String
  ruleId        String
  ruleVersionId String
  paragraphIndex Int
  blockIndex    Int?
  issue         String
  suggestion    String
  severity      Severity
  evidenceText  String?
  createdAt     DateTime   @default(now())
  reviewJob     ReviewJob  @relation(fields: [reviewJobId], references: [id], onDelete: Cascade)
  rule          Rule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  ruleVersion   RuleVersion @relation(fields: [ruleVersionId], references: [id], onDelete: Cascade)

  @@index([reviewJobId])
  @@index([ruleId])
  @@index([ruleVersionId])
  @@index([reviewJobId, paragraphIndex])
  @@index([reviewJobId, blockIndex])
}
